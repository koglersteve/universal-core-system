{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": [
    "src/server.ts",
    "src/routes/**/*.ts",
    "src/lib/prisma.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/lib/api",
    "src/autonomy",
    "src/dashboard",
    "src/eventbus",
    "src/health",
    "src/index.ts",
    "src/insight",
    "src/kernel",
    "src/middleware",
    "src/os",
    "src/plugins",
    "src/routes.api",
    "src/services",
    "src/types"
  ]
}
