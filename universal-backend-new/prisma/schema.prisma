generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  screenName  String
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts       Post[]
}

model Post {
  id         String   @id @default(cuid())
  type       String
  text       String?
  mediaUrl   String?
  score      Int      @default(0)
  createdAt  DateTime @default(now())

  creatorId  String
  creator    User     @relation(fields: [creatorId], references: [id])
}
