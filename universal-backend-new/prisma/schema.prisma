generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Represents a dramatic clip with its associated metadata.
model DramaClip {
  id        Int      @id @default(autoincrement())
  title     String
  videoUrl  String   @db.VarChar(2048) // Increased length for URLs
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Added for tracking updates

  favorites DramaFavorite[]
  views     DramaView[]
}