generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  screenName   String
  avatarUrl    String?
  createdAt    DateTime   @default(now())
  lafflabItems LAFFItem[]
  posts        Post[]
}

model Post {
  id        String   @id @default(cuid())
  type      String
  text      String?
  mediaUrl  String?
  score     Int      @default(0)
  createdAt DateTime @default(now())
  creatorId String
  app       String?
  creator   User     @relation(fields: [creatorId], references: [id])
}

model LAFFItem {
  id        String   @id @default(cuid())
  type      String
  text      String?
  mediaUrl  String?
  caption   String?
  score     Int      @default(0)
  createdAt DateTime @default(now())
  creatorId String
  app       String?
  creator   User     @relation(fields: [creatorId], references: [id])
}
