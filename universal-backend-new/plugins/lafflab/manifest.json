{
  "id": "lafflab",
  "name": "LAFFlab",
  "version": "1.0.0",
  "description": "Emotion-aware joke lab with cross-app orchestration across the Aurelia-Q OS.",
  "entry": "./index.ts",

  "routes": [
    "/lafflab",
    "/lafflab/jokes/random",
    "/lafflab/jokes/category/:id",
    "/lafflab/jokes/search",
    "/lafflab/favorites",
    "/lafflab/favorites/add",
    "/lafflab/history",
    "/lafflab/history/add",
    "/lafflab/categories",
    "/lafflab/emotion-link",
    "/lafflab/cross-app",
    "/lafflab/premium",
    "/lafflab/premium/activate",
    "/lafflab/ritual",
    "/lafflab/ritual/complete",
    "/lafflab/couples",
    "/lafflab/couples/session",
    "/lafflab/analytics"
  ],

  "permissions": [
    "user:profile",
    "user:mood",
    "cross-app:launch",
    "notifications",
    "analytics:write"
  ],

  "ui": {
    "appEntry": "LaffLabHome"
  },

  "features": {
    "emotionalLinkEngine": true,
    "crossAppLauncher": true,
    "dailyLaughRitual": true,
    "couplesMode": true,
    "premium": true
  }
}
