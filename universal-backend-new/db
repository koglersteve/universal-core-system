app.get("/feed", async (req, reply) => {
  try {
    const { cursor, limit = 10, app: appFilter } = req.query as {
      cursor?: string;
      limit?: string | number;
      app?: string;
    };

    const take = Number(limit) || 10;

    // If cursor is provided but no record exists, skip cursor logic
    let cursorObj = undefined;
    if (cursor) {
      const exists = await prisma.post.findUnique({ where: { id: cursor } });
      if (exists) {
        cursorObj = { id: cursor };
      }
    }

    const posts = await prisma.post.findMany({
      where: appFilter ? { app: appFilter } : {},
      take,
      skip: cursorObj ? 1 : 0,
      cursor: cursorObj,
      orderBy: { createdAt: "desc" },
      include: {
        creator: {
          select: {
            id: true,
            screenName: true,
            avatarUrl: true,
          },
        },
      },
    });

    const nextCursor =
      posts.length === take ? posts[posts.length - 1].id : null;

    return reply.send({
      items: posts,
      nextCursor,
    });
  } catch (err) {
    app.log.error(err);
    return reply.status(500).send({ error: "Feed service failed" });
  }
});
