generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Meme {
  id        String   @id @default(cuid())
  title     String
  mood      String?
  world     String?
  trait     String?
  agent     String?
  layers    Json
  createdAt DateTime @default(now())
}
