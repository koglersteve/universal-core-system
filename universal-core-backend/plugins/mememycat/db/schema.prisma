datasource db {
  provider = "sqlite"
  url      = "file:./mememycat.db"
}

generator client {
  provider = "prisma-client-js"
}

model CatMeme {
  id        Int      @id @default(autoincrement())
  userId    String
  imageUrl  String
  template  String?
  title     String?
  createdAt DateTime @default(now())
}
