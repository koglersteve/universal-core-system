datasource db {
  provider = "sqlite"
  url      = "file:./idlyily.db"
}

generator client {
  provider = "prisma-client-js"
}

model Meme {
  id        Int      @id @default(autoincrement())
  userId    String
  imageUrl  String
  template  String?
  title     String?
  couples   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Prompt {
  id        Int      @id @default(autoincrement())
  userId    String
  text      String
  createdAt DateTime @default(now())
}

