model lafflabJokes {
  id          String   @id @default(cuid())
  text        String
  category_id String?
  category    lafflabCategories? @relation(fields: [category_id], references: [id])
  created_at  DateTime @default(now())

  favorites lafflabFavorites[]
  history   lafflabHistory[]
  reactions lafflabReactions[]
}

model lafflabCategories {
  id    String @id @default(cuid())
  name  String
  jokes lafflabJokes[]
}

model lafflabFavorites {
  id       String   @id @default(cuid())
  user_id  String
  joke_id  String
  created_at DateTime @default(now())

  joke lafflabJokes @relation(fields: [joke_id], references: [id])

  @@unique([user_id, joke_id], name: "user_id_joke_id")
}

model lafflabHistory {
  id       String   @id @default(cuid())
  user_id  String
  joke_id  String
  seen_at  DateTime @default(now())

  joke lafflabJokes @relation(fields: [joke_id], references: [id])
}

model lafflabReactions {
  id        String   @id @default(cuid())
  user_id   String
  joke_id   String
  reaction  String
  mood_before String?
  mood_after  String?
  created_at DateTime @default(now())

  joke lafflabJokes @relation(fields: [joke_id], references: [id])
}

model lafflabCrossAppLinks {
  id         String   @id @default(cuid())
  user_id    String
  joke_id    String
  target_app String
  created_at DateTime @default(now())

  joke lafflabJokes @relation(fields: [joke_id], references: [id])
}

model lafflabPremium {
  user_id     String  @id
  product_id  String
  activated_at DateTime @default(now())
}
