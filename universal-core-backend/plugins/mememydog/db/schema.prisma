datasource db {
  provider = "sqlite"
  url      = "file:./mememydog.db"
}

generator client {
  provider = "prisma-client-js"
}

model DogMeme {
  id        Int      @id @default(autoincrement())
  userId    String
  imageUrl  String
  template  String?
  title     String?
  createdAt DateTime @default(now())
}
