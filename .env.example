# -------------------------
# Backend
# -------------------------
PORT=4000
DATABASE_URL="file:./dev.db"

# CORS
CORS_ORIGIN="http://localhost:3000"

# -------------------------
# Frontend
# -------------------------
NEXT_PUBLIC_API_URL="http://localhost:4000"

# -------------------------
# Auth / Security
# -------------------------
JWT_SECRET=changeme
JWT_EXPIRES_IN=1d

# Optional: encryption for sensitive fields
CRYPTO_KEY=

# -------------------------
# Stripe (optional but expected)
# -------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# -------------------------
# Email (optional)
# -------------------------
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME="Emotional OS"

# -------------------------
# App URLs (for emails, redirects)
# -------------------------
APP_URL="http://localhost:3000"

# -------------------------
# Logging / Debug
# -------------------------
NODE_ENV=development
LOG_LEVEL=info

# -------------------------
# Feature Flags (optional)
# -------------------------
ENABLE_IDLYILY=true
ENABLE_HOA_MEME=true
ENABLE_DRAMANEXTDOOR=true

